# Docker Environment Variables
# Copy this file to .env for docker-compose

# PostgreSQL Configuration
POSTGRES_USER=webet_user
POSTGRES_PASSWORD=webet_pass
POSTGRES_DB=webet_db

# Database URL (used by backend and database services)
DATABASE_URL=postgresql://webet_user:webet_pass@postgres:5432/webet_db

# Redis
REDIS_URL=redis://redis:6379

# JWT & Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars
GOOGLE_CLIENT_ID=your-google-oauth-client-id-from-console
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret-from-console

# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# AI Agent
GOOGLE_AI_API_KEY=your-google-generative-ai-api-key
BACKEND_API_URL=http://backend:3001
WEBHOOK_SECRET=your-webhook-secret-key-generate-random-string

# Admin Seed Data
ADMIN_EMAIL=admin@webet.com
ADMIN_PASSWORD=SecurePassword123!
ADMIN_NAME=Super Admin

# Optional: Sample Data
SEED_SAMPLE_DATA=false
